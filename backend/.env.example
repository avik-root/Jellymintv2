# Jellymint Chatbot Configuration

# Port to run the server on
PORT=3000

# Ollama API Host
OLLAMA_HOST=http://127.0.0.1:11434

# Encryption Key (Must be 32 bytes in hex, i.e., 64 characters)
# If left blank, the server will generate a secure key automatically on startup.
ENCRYPTION_KEY=

# Ngrok Auth Token (Optional)
# If provided, the server will automatically start an ngrok tunnel.
# Get yours at https://dashboard.ngrok.com/
NGROK_AUTHTOKEN=
